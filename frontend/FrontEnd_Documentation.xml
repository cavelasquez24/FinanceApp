        <div className="p-6 border-b border-[#EFEAE2]">
          <h2 className="text-lg font-semibold text-[#2C2A29]">Detalle de Activos</h2>
        </div>
        <div className="overflow-x-auto">
          <table className="w-full text-left border-collapse">
