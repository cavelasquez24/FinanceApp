export function DeleteCategoryModal({ isOpen, onClose, category }: Props) {
  const deleteMutation = useDeleteCategory();

  if (!isOpen || !category) return null;

  const handleDelete = () => {
    deleteMutation.mutate(category.id, {
      onSuccess: () => onClose(),
    });
